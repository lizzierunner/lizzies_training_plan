<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>IRON LIZZIE — RUNNING FROM DEADLINES</title>
<link href="https://fonts.googleapis.com/css2?family=Bangers&family=Permanent+Marker&family=Comic+Neue:wght@400;700&display=swap" rel="stylesheet">
<style>
:root {
  --ink: #0a0a0a;
  --paper: #f5f0e1;
  --yellow: #FFE338;
  --red: #E8142A;
  --blue: #1A47B8;
  --cyan: #00CFFF;
  --green: #00D166;
  --purple: #8B5CF6;
  --orange: #FF6B2B;
  --panel-bg: #fff;
  --outline: 3px solid var(--ink);
  --outline-thick: 4px solid var(--ink);
  --gutter: 6px;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: var(--paper);
  font-family: 'Comic Neue', cursive;
  min-height: 100vh;
  max-width: 500px;
  margin: 0 auto;
  overflow-x: hidden;
  position: relative;
}

body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image: radial-gradient(circle, rgba(0,0,0,0.06) 1px, transparent 1px);
  background-size: 5px 5px;
  pointer-events: none;
  z-index: 0;
}

body::after {
  content: '';
  position: fixed;
  inset: 0;
  background:
    linear-gradient(90deg, rgba(139,109,71,0.12) 0%, transparent 3%, transparent 97%, rgba(139,109,71,0.12) 100%),
    linear-gradient(180deg, rgba(139,109,71,0.08) 0%, transparent 2%, transparent 98%, rgba(139,109,71,0.08) 100%);
  pointer-events: none;
  z-index: 0;
}

/* SPLASH SCREEN */
.splash-screen {
  position: fixed;
  inset: 0;
  z-index: 10000;
  background: var(--ink);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: opacity 0.6s, transform 0.6s;
}
.splash-screen.dismissed {
  opacity: 0;
  transform: scale(1.1);
  pointer-events: none;
}
.splash-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse at 50% 40%, var(--red) 0%, transparent 60%),
    radial-gradient(ellipse at 30% 70%, var(--blue) 0%, transparent 50%),
    var(--ink);
  opacity: 0.4;
}
.splash-rays {
  position: absolute;
  inset: -50%;
  background: repeating-conic-gradient(
    from 0deg,
    transparent 0deg,
    transparent 8deg,
    rgba(255,227,56,0.06) 8deg,
    rgba(255,227,56,0.06) 16deg
  );
  animation: splashSpin 30s linear infinite;
}
@keyframes splashSpin { to { transform: rotate(360deg); } }

.splash-content {
  position: relative;
  z-index: 2;
  text-align: center;
  animation: splashPulse 2s ease-in-out infinite;
}
@keyframes splashPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.02); }
}
.splash-issue {
  font-family: 'Comic Neue', cursive;
  font-weight: 700;
  font-size: 11px;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--yellow);
  margin-bottom: 12px;
}
.splash-title {
  font-family: 'Bangers', cursive;
  font-size: 64px;
  line-height: 0.85;
  letter-spacing: 5px;
  color: white;
  text-shadow:
    4px 4px 0 var(--red),
    8px 8px 0 rgba(0,0,0,0.5);
  margin-bottom: 8px;
}
.splash-sub {
  font-family: 'Bangers', cursive;
  font-size: 22px;
  letter-spacing: 6px;
  color: var(--yellow);
  text-shadow: 2px 2px 0 var(--ink);
  margin-bottom: 6px;
}
.splash-tagline {
  font-family: 'Permanent Marker', cursive;
  font-size: 13px;
  letter-spacing: 2px;
  color: var(--cyan);
  margin-bottom: 24px;
}
.splash-hero-silhouette {
  font-size: 80px;
  filter: drop-shadow(0 0 20px var(--yellow)) drop-shadow(0 0 40px var(--red));
  margin-bottom: 16px;
  animation: heroFloat 3s ease-in-out infinite;
}
@keyframes heroFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8px); }
}
.splash-cta {
  font-family: 'Bangers', cursive;
  font-size: 18px;
  letter-spacing: 3px;
  color: white;
  animation: ctaBlink 1.5s ease-in-out infinite;
}
@keyframes ctaBlink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}
.splash-corner {
  position: absolute;
  font-family: 'Comic Neue', cursive;
  font-weight: 700;
  font-size: 9px;
  letter-spacing: 1px;
  color: rgba(255,255,255,0.3);
  text-transform: uppercase;
}
.splash-corner.tl { top: 16px; left: 16px; }
.splash-corner.tr { top: 16px; right: 16px; }
.splash-corner.bl { bottom: 16px; left: 16px; }
.splash-corner.br { bottom: 16px; right: 16px; }

/* MAIN WRAPPER */
.comic-page {
  padding: 8px;
  position: relative;
  z-index: 1;
}

.page-border {
  border: 3px solid var(--ink);
  background: white;
  box-shadow:
    inset 0 0 40px rgba(0,0,0,0.03),
    8px 8px 0 rgba(0,0,0,0.15);
  padding: var(--gutter);
  position: relative;
}

.ink-splatter {
  position: absolute;
  width: 30px;
  height: 30px;
  background: var(--ink);
  border-radius: 50% 40% 60% 30%;
  opacity: 0.08;
  pointer-events: none;
  z-index: 0;
}
.ink-splatter:nth-child(1) { top: -5px; left: 20%; transform: scale(0.8) rotate(45deg); }
.ink-splatter:nth-child(2) { top: 30%; right: -4px; transform: scale(0.5) rotate(120deg); }
.ink-splatter:nth-child(3) { bottom: 10%; left: -3px; transform: scale(0.6) rotate(200deg); }

/* MASTHEAD */
.masthead {
  background: var(--yellow);
  border: var(--outline-thick);
  border-bottom: 6px solid var(--ink);
  padding: 14px 16px 12px;
  margin-bottom: var(--gutter);
  position: relative;
  box-shadow: 4px 4px 0 var(--ink);
  animation: panelSlam 0.5s cubic-bezier(0.34,1.56,0.64,1) both;
  overflow: hidden;
}
.masthead::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 200%;
  height: 200%;
  background: repeating-linear-gradient(
    -60deg,
    transparent,
    transparent 4px,
    rgba(0,0,0,0.03) 4px,
    rgba(0,0,0,0.03) 5px
  );
  pointer-events: none;
}
.masthead-vol {
  font-family: 'Comic Neue', cursive;
  font-weight: 700;
  font-size: 10px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--ink);
  display: flex;
  justify-content: space-between;
  margin-bottom: 4px;
  position: relative;
  z-index: 1;
}
.masthead h1 {
  font-family: 'Bangers', cursive;
  font-size: 56px;
  letter-spacing: 5px;
  line-height: 0.88;
  color: var(--ink);
  text-shadow: 3px 3px 0 var(--red), 6px 6px 0 rgba(0,0,0,0.1);
  position: relative;
  z-index: 1;
}
.masthead-sub {
  font-family: 'Bangers', cursive;
  font-size: 16px;
  letter-spacing: 4px;
  color: var(--red);
  margin-top: 4px;
  position: relative;
  z-index: 1;
}
.masthead-badge {
  position: absolute;
  top: -2px;
  right: 10px;
  background: var(--red);
  color: white;
  font-family: 'Bangers', cursive;
  font-size: 12px;
  letter-spacing: 1px;
  padding: 6px 10px 4px;
  border: 2px solid var(--ink);
  transform: rotate(3deg);
  box-shadow: 2px 2px 0 var(--ink);
  z-index: 2;
}

/* HERO STRIP */
.hero-strip {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--gutter);
  margin-bottom: var(--gutter);
  animation: panelSlam 0.5s 0.05s cubic-bezier(0.34,1.56,0.64,1) both;
}

.xp-panel {
  background: var(--blue);
  border: var(--outline-thick);
  border-bottom: 5px solid var(--ink);
  padding: 10px 12px;
  box-shadow: 3px 3px 0 var(--ink);
  position: relative;
  overflow: hidden;
}
.xp-panel::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle, rgba(255,255,255,0.08) 1px, transparent 1px);
  background-size: 5px 5px;
}
.xp-label {
  font-family: 'Bangers', cursive;
  font-size: 11px;
  letter-spacing: 2px;
  color: var(--yellow);
  position: relative;
  z-index: 1;
}
.xp-value {
  font-family: 'Bangers', cursive;
  font-size: 32px;
  color: white;
  text-shadow: 2px 2px 0 var(--ink);
  line-height: 1;
  position: relative;
  z-index: 1;
}
.xp-rank {
  font-family: 'Permanent Marker', cursive;
  font-size: 10px;
  letter-spacing: 1px;
  color: var(--cyan);
  position: relative;
  z-index: 1;
  margin-top: 2px;
}

.villain-panel {
  background: var(--ink);
  border: 3px solid var(--red);
  border-bottom: 5px solid var(--red);
  padding: 10px 12px;
  box-shadow: 3px 3px 0 var(--red);
  position: relative;
  overflow: hidden;
}
.villain-panel::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle, rgba(232,20,42,0.1) 1px, transparent 1px);
  background-size: 5px 5px;
}
.villain-label {
  font-family: 'Bangers', cursive;
  font-size: 11px;
  letter-spacing: 2px;
  color: var(--red);
  position: relative;
  z-index: 1;
}
.villain-value {
  font-family: 'Bangers', cursive;
  font-size: 32px;
  color: var(--yellow);
  text-shadow: 2px 2px 0 var(--red);
  line-height: 1;
  position: relative;
  z-index: 1;
}
.villain-name {
  font-family: 'Permanent Marker', cursive;
  font-size: 10px;
  letter-spacing: 1px;
  color: var(--red);
  position: relative;
  z-index: 1;
  margin-top: 2px;
}

/* POWER METER */
.power-panel {
  background: linear-gradient(135deg, var(--purple) 0%, var(--blue) 100%);
  border: var(--outline-thick);
  border-bottom: 5px solid var(--ink);
  padding: 10px 14px;
  margin-bottom: var(--gutter);
  box-shadow: 4px 4px 0 var(--ink);
  animation: panelSlam 0.5s 0.08s cubic-bezier(0.34,1.56,0.64,1) both;
  position: relative;
  overflow: hidden;
}
.power-panel::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle, rgba(255,255,255,0.07) 1px, transparent 1px);
  background-size: 5px 5px;
}
.power-label {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6px;
  position: relative;
  z-index: 1;
}
.power-label span {
  font-family: 'Bangers', cursive;
  font-size: 16px;
  letter-spacing: 2px;
  color: var(--yellow);
}
.power-label .pct {
  font-family: 'Bangers', cursive;
  font-size: 28px;
  color: white;
  text-shadow: 2px 2px 0 var(--ink);
}
.power-track {
  height: 20px;
  background: var(--ink);
  border: 2px solid var(--ink);
  border-radius: 2px;
  overflow: hidden;
  position: relative;
  z-index: 1;
}
.power-fill {
  height: 100%;
  background: repeating-linear-gradient(
    90deg,
    var(--yellow) 0px,
    var(--yellow) 16px,
    var(--red) 16px,
    var(--red) 18px
  );
  transition: width 1.2s cubic-bezier(0.34,1.56,0.64,1);
  position: relative;
}
.power-fill::after {
  content: '\25B6\25B6\25B6';
  position: absolute;
  right: 4px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 8px;
  color: var(--ink);
  letter-spacing: -2px;
}
.power-markers {
  display: flex;
  justify-content: space-between;
  margin-top: 3px;
  position: relative;
  z-index: 1;
}
.power-markers span {
  font-family: 'Comic Neue', cursive;
  font-weight: 700;
  font-size: 8px;
  color: rgba(255,255,255,0.5);
  letter-spacing: 1px;
}

/* SECTION LABELS */
.section-label {
  font-family: 'Bangers', cursive;
  font-size: 12px;
  letter-spacing: 3px;
  color: white;
  background: var(--ink);
  border: 2px solid var(--ink);
  padding: 3px 10px 2px;
  display: inline-block;
  margin-bottom: 5px;
  position: relative;
  z-index: 1;
}
.section-label.red { background: var(--red); }
.section-label.blue { background: var(--blue); }

/* WEEK GRID */
.week-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 3px;
  margin-bottom: var(--gutter);
  position: relative;
  z-index: 1;
}
.week-cell {
  aspect-ratio: 1;
  background: white;
  border: 2px solid var(--ink);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: transform 0.15s, box-shadow 0.15s;
  box-shadow: 2px 2px 0 var(--ink);
  gap: 1px;
  position: relative;
  overflow: hidden;
}
.week-cell::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle, rgba(0,0,0,0.04) 1px, transparent 1px);
  background-size: 4px 4px;
}
.week-cell:active { transform: scale(0.92) translate(2px,2px); box-shadow: 0 0 0 var(--ink); }
.week-cell .cell-emoji { font-size: 18px; position: relative; z-index: 1; }
.week-cell .cell-day { font-size: 7px; font-weight: 700; letter-spacing: 0.5px; color: var(--ink); position: relative; z-index: 1; text-transform: uppercase; }
.week-cell.cell-done { background: var(--green); }
.week-cell.cell-done .cell-emoji { animation: doneBounce 0.5s ease; }
.week-cell.cell-today { background: var(--yellow); border-width: 3px; animation: cellPulse 2s infinite; }
.week-cell.cell-active { outline: 3px solid var(--red); outline-offset: 1px; }
.week-cell.cell-rest { background: #e8e2d6; }

@keyframes cellPulse {
  0%,100% { box-shadow: 2px 2px 0 var(--ink); }
  50% { box-shadow: 2px 2px 0 var(--red), 4px 4px 0 var(--ink); }
}
@keyframes doneBounce {
  0%,100% { transform: scale(1); }
  40% { transform: scale(1.3); }
  70% { transform: scale(0.9); }
}

/* SPEECH BUBBLE */
.speech-bubble {
  background: white;
  border: var(--outline-thick);
  border-radius: 18px 18px 18px 4px;
  padding: 12px 14px;
  margin-bottom: var(--gutter);
  position: relative;
  box-shadow: 4px 4px 0 var(--ink);
  animation: panelSlam 0.4s 0.12s cubic-bezier(0.34,1.56,0.64,1) both;
  z-index: 1;
}
.speech-bubble::before {
  content: '';
  position: absolute;
  bottom: -16px;
  left: 22px;
  border: 8px solid transparent;
  border-top: 10px solid var(--ink);
}
.speech-bubble::after {
  content: '';
  position: absolute;
  bottom: -11px;
  left: 24px;
  border: 6px solid transparent;
  border-top: 7px solid white;
}
.bubble-who {
  font-family: 'Bangers', cursive;
  font-size: 11px;
  letter-spacing: 2px;
  color: var(--red);
  margin-bottom: 3px;
  text-transform: uppercase;
}
.bubble-text {
  font-family: 'Comic Neue', cursive;
  font-size: 14px;
  font-weight: 700;
  color: var(--ink);
  line-height: 1.4;
}

/* FLOATING SFX */
.floating-sfx {
  position: fixed;
  pointer-events: none;
  z-index: 9000;
  inset: 0;
}
.sfx-word {
  position: absolute;
  font-family: 'Bangers', cursive;
  animation: sfxFloat 4s ease-out forwards;
  opacity: 0;
}
@keyframes sfxFloat {
  0% { opacity: 0; transform: translateY(0) scale(0.5) rotate(-10deg); }
  15% { opacity: 0.12; transform: translateY(-20px) scale(1) rotate(-5deg); }
  70% { opacity: 0.06; }
  100% { opacity: 0; transform: translateY(-120px) scale(1.2) rotate(5deg); }
}

/* DAY TABS */
.day-tabs {
  display: flex;
  gap: 4px;
  overflow-x: auto;
  padding-bottom: 4px;
  margin-bottom: var(--gutter);
  scrollbar-width: none;
  position: relative;
  z-index: 1;
}
.day-tabs::-webkit-scrollbar { display: none; }
.day-tab {
  flex-shrink: 0;
  font-family: 'Bangers', cursive;
  font-size: 13px;
  letter-spacing: 1.5px;
  padding: 5px 10px;
  border: 2px solid var(--ink);
  background: white;
  color: var(--ink);
  cursor: pointer;
  box-shadow: 2px 2px 0 var(--ink);
  transition: all 0.15s;
  white-space: nowrap;
  position: relative;
  overflow: hidden;
}
.day-tab::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle, rgba(0,0,0,0.03) 1px, transparent 1px);
  background-size: 4px 4px;
}
.day-tab:active { transform: translate(2px,2px); box-shadow: 0 0 0 var(--ink); }
.day-tab.active { background: var(--yellow); border-width: 3px; transform: scale(1.05); }
.day-tab.done-tab { background: var(--green); color: white; }

/* WORKOUT PANEL */
.workout-panel {
  border: var(--outline-thick);
  border-bottom: 6px solid var(--ink);
  background: white;
  box-shadow: 5px 5px 0 var(--ink);
  margin-bottom: var(--gutter);
  overflow: hidden;
  position: relative;
  z-index: 1;
  animation: panelSlam 0.35s cubic-bezier(0.34,1.56,0.64,1) both;
}

.panel-header {
  padding: 14px 14px 12px;
  border-bottom: 3px solid var(--ink);
  position: relative;
  overflow: hidden;
}
.panel-header::before {
  content: '';
  position: absolute;
  inset: -50%;
  background: repeating-linear-gradient(
    -45deg,
    transparent,
    transparent 6px,
    rgba(0,0,0,0.05) 6px,
    rgba(0,0,0,0.05) 7px
  );
  pointer-events: none;
}
.panel-header::after {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle, rgba(0,0,0,0.07) 1px, transparent 1px);
  background-size: 5px 5px;
  pointer-events: none;
}
.panel-header.run-header { background: var(--red); }
.panel-header.strength-header { background: var(--blue); }
.panel-header.longrun-header { background: var(--yellow); }
.panel-header.rest-header { background: #bbb; }

.header-top-row {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  position: relative;
  z-index: 1;
}
.panel-icon {
  font-size: 44px;
  line-height: 1;
  filter: drop-shadow(2px 2px 0 rgba(0,0,0,0.4));
}
.panel-titles { flex: 1; }
.panel-title {
  font-family: 'Bangers', cursive;
  font-size: 38px;
  letter-spacing: 3px;
  line-height: 0.92;
  color: white;
  text-shadow: 3px 3px 0 var(--ink);
}
.panel-header.longrun-header .panel-title,
.panel-header.rest-header .panel-title { color: var(--ink); text-shadow: 2px 2px 0 rgba(0,0,0,0.15); }
.panel-subtitle {
  font-family: 'Bangers', cursive;
  font-size: 13px;
  letter-spacing: 2px;
  color: rgba(255,255,255,0.85);
  margin-top: 2px;
}
.panel-header.longrun-header .panel-subtitle,
.panel-header.rest-header .panel-subtitle { color: rgba(0,0,0,0.5); }

.pow-badge {
  position: absolute;
  top: 8px;
  right: 10px;
  font-family: 'Bangers', cursive;
  font-size: 20px;
  letter-spacing: 1px;
  padding: 14px 16px 12px;
  border: 3px solid var(--ink);
  transform: rotate(8deg);
  box-shadow: 2px 2px 0 var(--ink);
  z-index: 2;
  line-height: 1;
  background: var(--yellow);
  color: var(--ink);
  clip-path: polygon(50% 0%, 63% 10%, 80% 2%, 75% 20%, 98% 25%, 82% 38%, 100% 50%, 82% 62%, 98% 75%, 75% 80%, 80% 98%, 63% 90%, 50% 100%, 37% 90%, 20% 98%, 25% 80%, 2% 75%, 18% 62%, 0% 50%, 18% 38%, 2% 25%, 25% 20%, 20% 2%, 37% 10%);
}
.panel-header.longrun-header .pow-badge { background: var(--red); color: white; }
.panel-header.strength-header .pow-badge { background: var(--cyan); }

/* INTERVAL VISUAL */
.interval-visual {
  padding: 10px 14px;
  border-bottom: 2px solid var(--ink);
  background: #f9f5ed;
  background-image: radial-gradient(circle, rgba(0,0,0,0.04) 1px, transparent 1px);
  background-size: 5px 5px;
}
.interval-label {
  font-family: 'Bangers', cursive;
  font-size: 11px;
  letter-spacing: 2px;
  color: var(--ink);
  margin-bottom: 6px;
}
.interval-blocks {
  display: flex;
  gap: 3px;
  flex-wrap: wrap;
  align-items: center;
}
.iblock {
  height: 18px;
  border: 1.5px solid var(--ink);
  border-radius: 2px;
  transition: transform 0.3s;
}
.iblock:hover { transform: scaleY(1.3); }
.iblock.run { background: var(--red); width: 28px; }
.iblock.walk { background: var(--blue); width: 14px; opacity: 0.7; }
.interval-legend {
  display: flex;
  gap: 14px;
  margin-top: 6px;
  font-size: 10px;
  font-weight: 700;
  color: var(--ink);
}
.ileg-dot { width: 10px; height: 10px; border: 1.5px solid var(--ink); border-radius: 2px; display: inline-block; margin-right: 4px; vertical-align: middle; }

/* STEPS */
.steps-section { padding: 12px 14px; }
.steps-title {
  font-family: 'Bangers', cursive;
  font-size: 15px;
  letter-spacing: 3px;
  color: var(--red);
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  gap: 6px;
}
.steps-title::after { content: ''; flex: 1; height: 2px; background: var(--ink); }

.step {
  display: flex;
  gap: 10px;
  align-items: flex-start;
  padding: 10px 12px;
  border: 2px solid var(--ink);
  margin-bottom: 6px;
  background: white;
  cursor: pointer;
  transition: all 0.15s;
  box-shadow: 2px 2px 0 var(--ink);
  position: relative;
  overflow: hidden;
}
.step::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle, rgba(0,0,0,0.03) 1px, transparent 1px);
  background-size: 4px 4px;
}
.step:active { transform: translate(2px,2px); box-shadow: 0 0 0 var(--ink); }
.step.checked { background: var(--green); border-color: var(--ink); }
.step.checked::before { display: none; }
.step.checked::after {
  content: '';
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    45deg,
    transparent,
    transparent 8px,
    rgba(255,255,255,0.15) 8px,
    rgba(255,255,255,0.15) 9px
  );
  pointer-events: none;
}

.step-num {
  width: 24px;
  height: 24px;
  background: var(--ink);
  color: var(--yellow);
  font-family: 'Bangers', cursive;
  font-size: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 2px;
  position: relative;
  z-index: 1;
  transition: all 0.15s;
}
.step.checked .step-num { background: white; color: var(--green); font-size: 16px; }
.step.checked .step-num::after { content: '\2713'; font-weight: 900; }

.step-body { flex: 1; position: relative; z-index: 1; }
.step-text { font-size: 13px; font-weight: 700; color: var(--ink); line-height: 1.4; }
.step.checked .step-text { text-decoration: line-through; color: rgba(0,0,0,0.35); }
.step-time {
  font-family: 'Bangers', cursive;
  font-size: 11px;
  letter-spacing: 1px;
  color: var(--red);
  margin-top: 1px;
}
.step.checked .step-time { color: rgba(0,0,0,0.25); }

/* COMPLETE BUTTON */
.complete-wrap { padding: 0 14px 14px; }
.complete-btn {
  width: 100%;
  font-family: 'Bangers', cursive;
  font-size: 24px;
  letter-spacing: 4px;
  border: var(--outline-thick);
  border-bottom: 6px solid var(--ink);
  padding: 14px;
  cursor: pointer;
  transition: all 0.12s;
  box-shadow: 4px 4px 0 var(--ink);
  text-transform: uppercase;
  position: relative;
  overflow: hidden;
}
.complete-btn::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle, rgba(255,255,255,0.15) 1px, transparent 1px);
  background-size: 5px 5px;
}
.complete-btn:active { transform: translate(4px,5px); box-shadow: 0 0 0 var(--ink); border-bottom: var(--outline-thick); }
.run-btn { background: var(--red); color: white; }
.strength-btn { background: var(--blue); color: white; }
.long-btn { background: var(--yellow); color: var(--ink); }
.done-btn { background: var(--green) !important; color: white !important; }

/* SKIP BUTTON */
.skip-wrap {
  padding: 0 14px 14px;
  text-align: center;
}
.skip-btn {
  font-family: 'Comic Neue', cursive;
  font-weight: 700;
  font-size: 11px;
  letter-spacing: 1px;
  color: rgba(0,0,0,0.35);
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px 8px;
  transition: color 0.15s;
}
.skip-btn:hover { color: var(--orange); }
.skipped-btn {
  background: var(--orange) !important;
  color: white !important;
}
.skip-badge {
  display: inline-block;
  font-family: 'Bangers', cursive;
  font-size: 10px;
  letter-spacing: 1px;
  padding: 2px 8px 1px;
  background: var(--orange);
  color: white;
  border: 1.5px solid var(--ink);
  margin-bottom: 4px;
}
.week-cell.cell-skipped {
  background: var(--orange);
  opacity: 0.7;
}
.week-cell.cell-skipped .cell-emoji {
  filter: grayscale(0.3);
}

/* CAPTION BOX */
.caption-box {
  background: var(--yellow);
  border: 2px solid var(--ink);
  padding: 4px 10px 3px;
  font-family: 'Permanent Marker', cursive;
  font-size: 10px;
  letter-spacing: 2px;
  color: var(--ink);
  display: inline-block;
  margin-bottom: 5px;
  box-shadow: 2px 2px 0 var(--ink);
  position: relative;
  z-index: 1;
}

/* STORY RECAP */
.story-recap {
  background: var(--ink);
  border: 3px solid var(--ink);
  padding: 12px 14px;
  margin-top: 4px;
  position: relative;
  z-index: 1;
}
.story-recap::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle, rgba(255,255,255,0.04) 1px, transparent 1px);
  background-size: 4px 4px;
}
.recap-title {
  font-family: 'Bangers', cursive;
  font-size: 14px;
  letter-spacing: 3px;
  color: var(--yellow);
  margin-bottom: 8px;
  position: relative;
  z-index: 1;
}
.recap-text {
  font-family: 'Comic Neue', cursive;
  font-size: 12px;
  font-weight: 700;
  color: rgba(255,255,255,0.7);
  line-height: 1.5;
  position: relative;
  z-index: 1;
}
.recap-text em {
  color: var(--yellow);
  font-style: normal;
}
.recap-next {
  font-family: 'Bangers', cursive;
  font-size: 13px;
  letter-spacing: 2px;
  color: var(--red);
  margin-top: 10px;
  position: relative;
  z-index: 1;
}

/* PAGE NUMBER */
.page-number {
  text-align: center;
  font-family: 'Comic Neue', cursive;
  font-weight: 700;
  font-size: 10px;
  letter-spacing: 2px;
  color: rgba(0,0,0,0.3);
  margin-top: 8px;
  padding-bottom: 12px;
  position: relative;
  z-index: 1;
}

/* ACHIEVEMENT TOAST */
.achievement-toast {
  position: fixed;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%) translateY(100px);
  background: var(--ink);
  border: 3px solid var(--yellow);
  padding: 12px 20px;
  font-family: 'Bangers', cursive;
  font-size: 16px;
  letter-spacing: 2px;
  color: var(--yellow);
  z-index: 9999;
  box-shadow: 0 4px 20px rgba(0,0,0,0.5);
  transition: transform 0.5s cubic-bezier(0.34,1.56,0.64,1);
  white-space: nowrap;
  text-align: center;
}
.achievement-toast.show {
  transform: translateX(-50%) translateY(0);
}

/* CONFETTI */
.confetti-container { position: fixed; inset: 0; pointer-events: none; z-index: 9999; }

/* ACTION WORDS */
.action-word {
  position: fixed;
  font-family: 'Bangers', cursive;
  font-size: 80px;
  letter-spacing: 5px;
  pointer-events: none;
  z-index: 9998;
  top: 50%;
  left: 50%;
  transform: translate(-50%,-50%) rotate(-8deg);
  white-space: nowrap;
  animation: actionPop 1s cubic-bezier(0.34,1.56,0.64,1) forwards;
  -webkit-text-stroke: 3px var(--ink);
  color: var(--yellow);
  text-shadow:
    4px 4px 0 var(--red),
    -2px -2px 0 var(--ink),
    2px -2px 0 var(--ink),
    -2px 2px 0 var(--ink);
}
@keyframes actionPop {
  0% { opacity:0; transform: translate(-50%,-50%) scale(0.1) rotate(-15deg); }
  30% { opacity:1; transform: translate(-50%,-50%) scale(1.2) rotate(-8deg); }
  50% { transform: translate(-50%,-50%) scale(0.95) rotate(-5deg); }
  65% { transform: translate(-50%,-50%) scale(1.05) rotate(-8deg); }
  80% { opacity:1; }
  100% { opacity:0; transform: translate(-50%,-50%) scale(1.3) rotate(-8deg); }
}

.action-burst {
  position: fixed;
  top: 50%;
  left: 50%;
  width: 300px;
  height: 300px;
  transform: translate(-50%, -50%);
  pointer-events: none;
  z-index: 9997;
  animation: burstPop 1s ease-out forwards;
}
@keyframes burstPop {
  0% { opacity: 0; transform: translate(-50%, -50%) scale(0); }
  20% { opacity: 0.8; transform: translate(-50%, -50%) scale(1); }
  100% { opacity: 0; transform: translate(-50%, -50%) scale(1.5); }
}

@keyframes screenShake {
  0%,100% { transform: translate(0,0); }
  10% { transform: translate(-4px, 2px); }
  20% { transform: translate(4px, -2px); }
  30% { transform: translate(-2px, 4px); }
  40% { transform: translate(2px, -4px); }
  50% { transform: translate(-4px, 0); }
  60% { transform: translate(4px, 2px); }
  70% { transform: translate(-2px, -2px); }
  80% { transform: translate(2px, 4px); }
  90% { transform: translate(-4px, -4px); }
}
.shake { animation: screenShake 0.4s ease-out; }

@keyframes panelSlam {
  0% { opacity:0; transform: scale(0.8) rotate(-2deg); }
  60% { transform: scale(1.02) rotate(0.5deg); }
  100% { opacity:1; transform: scale(1) rotate(0deg); }
}

/* STREAK FLAMES */
.streak-display {
  display: flex;
  align-items: center;
  gap: 3px;
  margin-top: 3px;
}
.streak-flame {
  font-size: 10px;
  animation: flameFlicker 0.6s ease-in-out infinite alternate;
}
.streak-flame:nth-child(2) { animation-delay: 0.1s; }
.streak-flame:nth-child(3) { animation-delay: 0.2s; }
.streak-flame:nth-child(4) { animation-delay: 0.15s; }
.streak-flame:nth-child(5) { animation-delay: 0.25s; }
@keyframes flameFlicker {
  from { transform: scaleY(1) translateY(0); }
  to { transform: scaleY(1.2) translateY(-1px); }
}

/* MODE TOGGLE */
.mode-toggle-wrap {
  padding: 10px 14px;
  border-bottom: 2px solid var(--ink);
  background: #f9f5ed;
  background-image: radial-gradient(circle, rgba(0,0,0,0.04) 1px, transparent 1px);
  background-size: 5px 5px;
}
.mode-toggle-label {
  font-family: 'Bangers', cursive;
  font-size: 11px;
  letter-spacing: 2px;
  color: var(--ink);
  margin-bottom: 8px;
  display: flex;
  align-items: center;
  gap: 6px;
}
.mode-toggle-label::after {
  content: '';
  flex: 1;
  height: 2px;
  background: var(--ink);
}
.mode-toggle-btns {
  display: flex;
  gap: 0;
  border: 3px solid var(--ink);
  border-radius: 3px;
  overflow: hidden;
  box-shadow: 3px 3px 0 var(--ink);
}
.mode-btn {
  flex: 1;
  font-family: 'Bangers', cursive;
  font-size: 13px;
  letter-spacing: 1.5px;
  padding: 10px 8px 8px;
  border: none;
  cursor: pointer;
  transition: all 0.2s;
  text-align: center;
  line-height: 1.3;
  position: relative;
  background: white;
  color: var(--ink);
}
.mode-btn:first-child {
  border-right: 2px solid var(--ink);
}
.mode-btn .mode-emoji {
  display: block;
  font-size: 22px;
  margin-bottom: 2px;
}
.mode-btn .mode-text {
  display: block;
  font-size: 12px;
  letter-spacing: 1px;
}
.mode-btn .mode-sub {
  display: block;
  font-family: 'Comic Neue', cursive;
  font-weight: 700;
  font-size: 9px;
  letter-spacing: 0.5px;
  color: rgba(0,0,0,0.4);
  margin-top: 1px;
}
.mode-btn.mode-active {
  color: white;
}
.mode-btn.mode-active .mode-sub {
  color: rgba(255,255,255,0.7);
}
.mode-btn.outdoor-active {
  background: var(--red);
  box-shadow: inset 0 -3px 0 rgba(0,0,0,0.2);
}
.mode-btn.treadmill-active {
  background: var(--purple);
  box-shadow: inset 0 -3px 0 rgba(0,0,0,0.2);
}
.mode-btn:not(.mode-active):hover {
  background: #f0ece0;
}
.mode-btn::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle, rgba(255,255,255,0.12) 1px, transparent 1px);
  background-size: 4px 4px;
  opacity: 0;
  transition: opacity 0.2s;
}
.mode-btn.mode-active::before {
  opacity: 1;
}

/* IFIT BADGE */
.ifit-badge {
  display: inline-block;
  background: var(--purple);
  color: white;
  font-family: 'Bangers', cursive;
  font-size: 10px;
  letter-spacing: 1px;
  padding: 2px 6px 1px;
  border: 1.5px solid var(--ink);
  border-radius: 2px;
  margin-left: 6px;
  vertical-align: middle;
}

/* SWAP DAY FEATURE */
.swap-wrap {
  padding: 6px 14px 8px;
  border-bottom: 2px solid var(--ink);
  background: #faf7ef;
  background-image: radial-gradient(circle, rgba(0,0,0,0.03) 1px, transparent 1px);
  background-size: 4px 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}
.swap-btn {
  font-family: 'Bangers', cursive;
  font-size: 12px;
  letter-spacing: 2px;
  padding: 5px 12px 4px;
  border: 2px solid var(--ink);
  background: var(--orange);
  color: white;
  cursor: pointer;
  box-shadow: 2px 2px 0 var(--ink);
  transition: all 0.15s;
  display: flex;
  align-items: center;
  gap: 5px;
}
.swap-btn:active { transform: translate(2px,2px); box-shadow: 0 0 0 var(--ink); }
.swap-btn:hover { background: #ff8548; }
.swap-btn .swap-icon { font-size: 14px; }

.swap-label {
  font-family: 'Comic Neue', cursive;
  font-weight: 700;
  font-size: 10px;
  letter-spacing: 1px;
  color: var(--orange);
  text-transform: uppercase;
}

/* SWAP MODAL OVERLAY */
.swap-overlay {
  position: fixed;
  inset: 0;
  background: rgba(10,10,10,0.7);
  z-index: 9500;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: swapFadeIn 0.2s ease-out;
}
@keyframes swapFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
.swap-modal {
  background: white;
  border: 4px solid var(--ink);
  border-bottom: 6px solid var(--ink);
  box-shadow: 8px 8px 0 var(--ink);
  max-width: 340px;
  width: 90%;
  padding: 0;
  overflow: hidden;
  animation: panelSlam 0.35s cubic-bezier(0.34,1.56,0.64,1) both;
}
.swap-modal-header {
  background: var(--orange);
  border-bottom: 3px solid var(--ink);
  padding: 12px 14px 10px;
  position: relative;
}
.swap-modal-header::before {
  content: '';
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(-45deg, transparent, transparent 6px, rgba(0,0,0,0.05) 6px, rgba(0,0,0,0.05) 7px);
  pointer-events: none;
}
.swap-modal-title {
  font-family: 'Bangers', cursive;
  font-size: 24px;
  letter-spacing: 3px;
  color: white;
  text-shadow: 2px 2px 0 var(--ink);
  position: relative;
  z-index: 1;
}
.swap-modal-sub {
  font-family: 'Comic Neue', cursive;
  font-weight: 700;
  font-size: 11px;
  color: rgba(255,255,255,0.8);
  position: relative;
  z-index: 1;
}
.swap-modal-body { padding: 12px 14px; }
.swap-option {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 12px;
  border: 2px solid var(--ink);
  margin-bottom: 6px;
  cursor: pointer;
  box-shadow: 2px 2px 0 var(--ink);
  transition: all 0.15s;
  background: white;
  position: relative;
  overflow: hidden;
}
.swap-option::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle, rgba(0,0,0,0.03) 1px, transparent 1px);
  background-size: 4px 4px;
}
.swap-option:active { transform: translate(2px,2px); box-shadow: 0 0 0 var(--ink); }
.swap-option:hover { background: var(--yellow); }
.swap-option-emoji { font-size: 22px; position: relative; z-index: 1; }
.swap-option-info { flex: 1; position: relative; z-index: 1; }
.swap-option-day {
  font-family: 'Bangers', cursive;
  font-size: 14px;
  letter-spacing: 1px;
  color: var(--ink);
}
.swap-option-type {
  font-family: 'Comic Neue', cursive;
  font-weight: 700;
  font-size: 11px;
  color: rgba(0,0,0,0.5);
}
.swap-option-arrow {
  font-family: 'Bangers', cursive;
  font-size: 16px;
  color: var(--orange);
  position: relative;
  z-index: 1;
}
.swap-cancel {
  width: 100%;
  font-family: 'Bangers', cursive;
  font-size: 14px;
  letter-spacing: 2px;
  padding: 8px;
  border: 2px solid var(--ink);
  background: #eee;
  color: var(--ink);
  cursor: pointer;
  box-shadow: 2px 2px 0 var(--ink);
  margin-top: 4px;
}
.swap-cancel:active { transform: translate(2px,2px); box-shadow: 0 0 0 var(--ink); }
.swap-cancel:hover { background: #ddd; }

/* SWAP ACTIVE INDICATOR */
.swap-indicator {
  font-family: 'Comic Neue', cursive;
  font-weight: 700;
  font-size: 10px;
  color: var(--orange);
  letter-spacing: 1px;
  text-align: center;
  padding: 3px 0 0;
}
.swap-undo {
  font-family: 'Bangers', cursive;
  font-size: 11px;
  letter-spacing: 1px;
  padding: 3px 8px 2px;
  border: 1.5px solid var(--ink);
  background: white;
  color: var(--ink);
  cursor: pointer;
  box-shadow: 1px 1px 0 var(--ink);
  margin-left: 6px;
  transition: all 0.15s;
}
.swap-undo:active { transform: translate(1px,1px); box-shadow: 0 0 0; }
.swap-undo:hover { background: var(--yellow); }

@media (max-width: 380px) {
  .masthead h1 { font-size: 44px; }
  .splash-title { font-size: 48px; }
  .panel-title { font-size: 30px; }
  .xp-value, .villain-value { font-size: 26px; }
}
</style>
</head>
<body>

<!-- SPLASH SCREEN -->
<div class="splash-screen" id="splashScreen" onclick="dismissSplash()">
  <div class="splash-bg"></div>
  <div class="splash-rays"></div>
  <div class="splash-corner tl">MARVEL AT THE POWER OF</div>
  <div class="splash-corner tr">EST. MARCH 2026</div>
  <div class="splash-corner bl">ISSUE #1 OF INFINITY</div>
  <div class="splash-corner br">APPROVED BY THE COMICS CODE</div>
  <div class="splash-content">
    <div class="splash-issue">PRESENTING THE INCREDIBLE</div>
    <div class="splash-hero-silhouette">&#x1F9B8;&#x200D;&#x2640;&#xFE0F;</div>
    <div class="splash-title">IRON<br>LIZZIE</div>
    <div class="splash-sub">RUNNING FROM DEADLINES</div>
    <div class="splash-tagline">"She doesn't run FROM danger -- she runs THROUGH it."</div>
    <div class="splash-cta">-- TAP TO BEGIN YOUR ORIGIN STORY --</div>
  </div>
</div>

<!-- MAIN COMIC PAGE -->
<div class="confetti-container" id="confetti"></div>
<div class="floating-sfx" id="floatingSfx"></div>
<div class="achievement-toast" id="achievementToast"></div>

<div class="comic-page">
  <div class="page-border">
    <div class="ink-splatter"></div>
    <div class="ink-splatter"></div>
    <div class="ink-splatter"></div>

    <!-- MASTHEAD -->
    <div class="masthead">
      <div class="masthead-badge">&#x1F3C1; MAY 9 &middot; 10K</div>
      <div class="masthead-vol">
        <span>VOL. 1 &middot; ISSUE #<span id="issueNum">1</span></span>
        <span id="dateDisplay">MARCH 2026</span>
      </div>
      <h1>IRON<br>LIZZIE</h1>
      <div class="masthead-sub">&#x26A1; RUNNING FROM DEADLINES &#x26A1;</div>
    </div>

    <!-- HERO STRIP -->
    <div class="hero-strip">
      <div class="xp-panel">
        <div class="xp-label">&#x26A1; HERO XP</div>
        <div class="xp-value" id="xpValue">0</div>
        <div class="xp-rank" id="xpRank">RANK: SIDEKICK</div>
        <div class="streak-display" id="streakDisplay"></div>
      </div>
      <div class="villain-panel">
        <div class="villain-label">&#x1F480; RACE DAY IN</div>
        <div class="villain-value" id="villainCountdown">46</div>
        <div class="villain-name" id="villainName">THE DEADLINE APPROACHES</div>
      </div>
    </div>

    <!-- POWER METER -->
    <div class="power-panel">
      <div class="power-label">
        <span>&#x26A1; POWER LEVEL</span>
        <span class="pct" id="progressPct">0%</span>
      </div>
      <div class="power-track">
        <div class="power-fill" id="progressFill" style="width:0%"></div>
      </div>
      <div class="power-markers">
        <span>ORIGIN</span>
        <span>TRAINING</span>
        <span>HERO</span>
        <span>LEGEND</span>
      </div>
    </div>

    <!-- WEEK GRID -->
    <div class="section-label">&#x1F4C5; THIS WEEK'S MISSIONS</div>
    <div class="week-grid" id="weekGrid"></div>

    <!-- SPEECH BUBBLE -->
    <div class="speech-bubble">
