// STATE
function loadState() {
  try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); } catch(e) { return {}; }
}
function saveState(s) {
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(s)); } catch(e) {}
}

var state = loadState();
var activeDate = planDays[0].date;

var today = new Date().toISOString().split('T')[0];
var todayPlan = planDays.find(function(d){ return d.date === today; });
if (todayPlan) activeDate = today;
else {
  var upcoming = planDays.find(function(d){ return d.date >= today; });
  if (upcoming) activeDate = upcoming.date;
}

// SPLASH
function dismissSplash() {
  var splash = document.getElementById('splashScreen');
  splash.classList.add('dismissed');
  setTimeout(function(){ splash.style.display = 'none'; }, 700);
  setTimeout(spawnAmbientSfx, 1000);
}
if (state._splashSeen) {
  document.getElementById('splashScreen').style.display = 'none';
} else {
  state._splashSeen = true;
  saveState(state);
}

// DAY SWAP SYSTEM
// Swaps are stored as state._swaps = { 'dateA': 'dateB', 'dateB': 'dateA' }
// This means "the workout originally on dateA is now on dateB" and vice versa.
function getSwaps() {
  return (state._swaps) || {};
}

function getDayForDate(dateStr) {
  // Follow the swap chain: if dateStr is swapped, return the planDay whose original date is the swap target
  var swaps = getSwaps();
  var originalDate = swaps[dateStr] || dateStr;
  return planDays.find(function(d){ return d.date === originalDate; });
}

function getOriginalDayForDate(dateStr) {
  return planDays.find(function(d){ return d.date === dateStr; });
}

function isDateSwapped(dateStr) {
  var swaps = getSwaps();
  return swaps[dateStr] && swaps[dateStr] !== dateStr;
}

function swapDays(dateA, dateB) {
  if (!state._swaps) state._swaps = {};
  // Resolve current swap chain first
  var swaps = state._swaps;
  var realA = swaps[dateA] || dateA;
  var realB = swaps[dateB] || dateB;
  // Perform the swap
  swaps[dateA] = realB;
  swaps[dateB] = realA;
  // Also swap completion state
  var stateA = state[dateA] || {};
  var stateB = state[dateB] || {};
  // Preserve mode but swap done/steps
  var tempDone = stateA.done;
  var tempSteps = stateA.steps;
  var tempMode = stateA.mode;
  stateA.done = stateB.done;
  stateA.steps = stateB.steps;
  stateA.mode = stateB.mode;
  stateB.done = tempDone;
  stateB.steps = tempSteps;
  stateB.mode = tempMode;
  state[dateA] = stateA;
  state[dateB] = stateB;
  saveState(state);
}

function undoSwap(dateStr) {
  if (!state._swaps) return;
  var swaps = state._swaps;
  var partnerDate = swaps[dateStr];
  if (!partnerDate) return;
  // Undo by swapping them back
  swapDays(dateStr, partnerDate);
  // Now clear swap entries since they're back to original
  delete state._swaps[dateStr];
  delete state._swaps[partnerDate];
  saveState(state);
}

function getWeekDatesForDate(dateStr) {
  var d = new Date(dateStr + 'T12:00:00');
  var dayOfWeek = d.getDay();
  var weekStart = new Date(d);
  weekStart.setDate(d.getDate() - dayOfWeek);
  var dates = [];
  for (var i = 0; i < 7; i++) {
    var wd = new Date(weekStart);
    wd.setDate(weekStart.getDate() + i);
    dates.push(wd.toISOString().split('T')[0]);
  }
  return dates;
}

function showSwapModal(fromDate) {
  // Remove any existing modal
  var existing = document.querySelector('.swap-overlay');
  if (existing) existing.remove();

  var weekDates = getWeekDatesForDate(fromDate);
  var fromDay = getDayForDate(fromDate);
  var fromDateObj = new Date(fromDate + 'T12:00:00');

  var optionsHTML = '';
  weekDates.forEach(function(ds) {
    if (ds === fromDate) return;
    var day = getDayForDate(ds);
    if (!day) return;
    var dObj = new Date(ds + 'T12:00:00');
    var dayName = WEEK_DAYS[dObj.getDay()];
    var emoji = '\u2014';
    if (day.type === 'run') emoji = '\uD83C\uDFC3\u200D\u2640\uFE0F';
    else if (day.type === 'longrun') emoji = '\u2B50';
    else if (day.type === 'strength') emoji = '\uD83D\uDCAA';
    else if (day.type === 'rest') emoji = '\uD83D\uDE34';
    optionsHTML += '<div class="swap-option" data-swap-date="' + ds + '">' +
      '<div class="swap-option-emoji">' + emoji + '</div>' +
      '<div class="swap-option-info">' +
        '<div class="swap-option-day">' + dayName + ' ' + dObj.getDate() + '</div>' +
        '<div class="swap-option-type">' + day.title + '</div>' +
      '</div>' +
      '<div class="swap-option-arrow">\u21C4</div>' +
    '</div>';
  });

  var overlay = document.createElement('div');
  overlay.className = 'swap-overlay';
  overlay.innerHTML = '<div class="swap-modal">' +
    '<div class="swap-modal-header">' +
      '<div class="swap-modal-title">\uD83D\uDD00 SWAP DAY</div>' +
      '<div class="swap-modal-sub">Move ' + WEEK_DAYS[fromDateObj.getDay()] + '\'s workout to another day</div>' +
    '</div>' +
    '<div class="swap-modal-body">' +
      optionsHTML +
      '<button class="swap-cancel">\u2716 CANCEL</button>' +
    '</div>' +
  '</div>';

  document.body.appendChild(overlay);

  // Close on overlay click
  overlay.addEventListener('click', function(e) {
    if (e.target === overlay) overlay.remove();
  });

  // Cancel button
  overlay.querySelector('.swap-cancel').addEventListener('click', function() {
    overlay.remove();
  });

  // Swap option clicks
  overlay.querySelectorAll('.swap-option').forEach(function(opt) {
    opt.addEventListener('click', function() {
      var targetDate = opt.dataset.swapDate;
      swapDays(fromDate, targetDate);
      overlay.remove();
      renderAll();
    });
  });
}

// CALCULATIONS
function getCompletedCount() {
  return planDays.filter(function(d){ return state[d.date] && state[d.date].done; }).length;
}

function getTotalXP() {
  var xp = 0;
  planDays.forEach(function(d) {
    if (state[d.date] && state[d.date].done) {
      var swappedDay = getDayForDate(d.date);
      xp += (swappedDay ? swappedDay.xp : d.xp) || 30;
    }
  });
  return xp;
}

function getRank(xp) {
  var rank = RANKS[0];
  for (var i = 0; i < RANKS.length; i++) {
    if (xp >= RANKS[i].min) rank = RANKS[i];
  }
  return rank;
}

function getStreak() {
  var streak = 0;
  var sorted = planDays.slice().sort(function(a,b){ return b.date.localeCompare(a.date); });
  for (var i = 0; i < sorted.length; i++) {
    if (sorted[i].date > today) continue;
    if (state[sorted[i].date] && (state[sorted[i].date].done || state[sorted[i].date].skipped)) streak++;
    else break;
  }
  return streak;
}

function getDaysUntilRace() {
  var now = new Date();
  var diff = RACE_DATE - now;
  return Math.max(0, Math.ceil(diff / (1000 * 60 * 60 * 24)));
}

function getWeekNumber() {
  var start = new Date(planDays[0].date);
  var current = new Date(activeDate);
  return Math.floor((current - start) / (7 * 24 * 60 * 60 * 1000)) + 1;
}

// RENDER PROGRESS
function renderProgress() {
  var completed = getCompletedCount();
  var total = planDays.length;
  var pct = Math.round((completed / total) * 100);
  document.getElementById('progressPct').textContent = pct + '%';
  document.getElementById('progressFill').style.width = pct + '%';
}

// RENDER HERO STRIP
function renderHeroStrip() {
  var xp = getTotalXP();
  var rank = getRank(xp);
  var streak = getStreak();
  var daysLeft = getDaysUntilRace();

  document.getElementById('xpValue').textContent = xp + ' XP';
  document.getElementById('xpRank').textContent = 'RANK: ' + rank.emoji + ' ' + rank.name;

  var streakEl = document.getElementById('streakDisplay');
  if (streak > 0) {
    var flames = '';
    var flameCount = Math.min(streak, 7);
    for (var i = 0; i < flameCount; i++) flames += '<span class="streak-flame">\uD83D\uDD25</span>';
    streakEl.innerHTML = '<span style="font-family:Comic Neue;font-weight:700;font-size:9px;color:var(--yellow);letter-spacing:1px;">' + streak + ' DAY STREAK</span> ' + flames;
  } else {
    streakEl.innerHTML = '<span style="font-family:Comic Neue;font-weight:700;font-size:9px;color:rgba(255,255,255,0.4);letter-spacing:1px;">START YOUR STREAK!</span>';
  }

  document.getElementById('villainCountdown').textContent = daysLeft + ' DAYS';
  if (daysLeft <= 7) {
    document.getElementById('villainName').textContent = '\u26A0\uFE0F THE FINAL BATTLE IS NEAR';
  } else if (daysLeft <= 21) {
    document.getElementById('villainName').textContent = '\uD83D\uDD25 THE DEADLINE CLOSES IN';
  } else {
    document.getElementById('villainName').textContent = '\uD83D\uDC80 THE DEADLINE APPROACHES';
  }

  document.getElementById('issueNum').textContent = getWeekNumber();
  var d = new Date(activeDate + 'T12:00:00');
  document.getElementById('dateDisplay').textContent = MONTHS[d.getMonth()] + ' ' + d.getFullYear();
}

// RENDER WEEK GRID
function renderWeekGrid() {
  var grid = document.getElementById('weekGrid');
  grid.innerHTML = '';

  var active = new Date(activeDate + 'T12:00:00');
  var dayOfWeek = active.getDay();
  var weekStart = new Date(active);
  weekStart.setDate(active.getDate() - dayOfWeek);

  for (var i = 0; i < 7; i++) {
    var d = new Date(weekStart);
    d.setDate(weekStart.getDate() + i);
    var ds = d.toISOString().split('T')[0];
    var day = getDayForDate(ds);
    var hasOriginalPlan = getOriginalDayForDate(ds);
    var isDone = state[ds] && state[ds].done;
    var isSkipped = state[ds] && state[ds].skipped;
    var isToday = ds === today;
    var isActive = ds === activeDate;
    var isSwapped = isDateSwapped(ds);

    var cell = document.createElement('div');
    cell.className = 'week-cell' +
      (isDone ? ' cell-done' : '') +
      (isSkipped ? ' cell-skipped' : '') +
      (isToday ? ' cell-today' : '') +
      (isActive ? ' cell-active' : '') +
      (!hasOriginalPlan ? ' cell-rest' : '');

    var emoji = '\u2014';
    if (day) {
      if (isDone) emoji = '\u2705';
      else if (isSkipped) emoji = '\u23ED\uFE0F';
      else if (day.type === 'run') emoji = '\uD83C\uDFC3\u200D\u2640\uFE0F';
      else if (day.type === 'longrun') emoji = '\u2B50';
      else if (day.type === 'strength') emoji = '\uD83D\uDCAA';
      else if (day.type === 'rest') emoji = '\uD83D\uDE34';
    }

    var swapMarker = isSwapped ? '<span style="position:absolute;top:1px;right:2px;font-size:8px;">\uD83D\uDD00</span>' : '';
    cell.innerHTML = swapMarker + '<span class="cell-emoji">' + emoji + '</span><span class="cell-day">' + WEEK_DAYS[d.getDay()] + '</span>';
    if (hasOriginalPlan) {
      (function(dateStr){
        cell.addEventListener('click', function(){ activeDate = dateStr; renderAll(); });
      })(ds);
    }
    grid.appendChild(cell);
  }
}

// RENDER MOTO
function renderMoto() {
  var day = getDayForDate(activeDate);
  if (!day) return;
  var mode = (state[activeDate] && state[activeDate].mode) || 'outdoor';
  var motoText = (mode === 'treadmill' && day.ifitMoto) ? day.ifitMoto : day.moto;
  document.getElementById('motoText').textContent = motoText;
}

// RENDER TABS
function renderTabs() {
  var tabs = document.getElementById('dayTabs');
  tabs.innerHTML = '';
  planDays.forEach(function(day) {
    var isDone = state[day.date] && state[day.date].done;
    var isSkipped = state[day.date] && state[day.date].skipped;
    var isActive = day.date === activeDate;
    var swapped = isDateSwapped(day.date);
    var tab = document.createElement('button');
    tab.className = 'day-tab' + (isActive ? ' active' : '') + (isDone && !isActive ? ' done-tab' : '') + (isSkipped && !isActive ? ' done-tab' : '');
    if (isSkipped && !isActive) tab.style.background = 'var(--orange)';
    var d = new Date(day.date + 'T12:00:00');
    var label = WEEK_DAYS[d.getDay()].slice(0,3) + ' ' + d.getDate();
    tab.textContent = (isDone ? '\u2713 ' : '') + (isSkipped ? '\u23ED ' : '') + (swapped ? '\uD83D\uDD00 ' : '') + label;
    tab.addEventListener('click', function() {
      activeDate = day.date;
      renderAll();
      setTimeout(function(){ tab.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' }); }, 50);
    });
    tabs.appendChild(tab);
  });

  setTimeout(function() {
    var activeTab = tabs.querySelector('.active');
    if (activeTab) activeTab.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
  }, 100);
}

// RENDER WORKOUT
function renderWorkout() {
  var day = getDayForDate(activeDate);
  var content = document.getElementById('workoutContent');
  content.innerHTML = '';
  if (!day) return;

  var isDone = state[activeDate] && state[activeDate].done;
  var isSkipped = state[activeDate] && state[activeDate].skipped;
  var checkedSteps = (state[activeDate] && state[activeDate].steps) || {};
  var hasIfitOption = day.ifitSteps && day.ifitSteps.length > 0;
  var currentMode = (state[activeDate] && state[activeDate].mode) || 'outdoor';

  // MODE TOGGLE (only for run/longrun days with iFit data)
  var toggleHTML = '';
  if (hasIfitOption) {
    toggleHTML = '<div class="mode-toggle-wrap">' +
      '<div class="mode-toggle-label">\uD83C\uDF26\uFE0F CHOOSE YOUR ADVENTURE</div>' +
      '<div class="mode-toggle-btns">' +
        '<button class="mode-btn ' + (currentMode === 'outdoor' ? 'mode-active outdoor-active' : '') + '" data-mode="outdoor">' +
          '<span class="mode-emoji">\uD83C\uDF33</span>' +
          '<span class="mode-text">OUTDOOR</span>' +
          '<span class="mode-sub">Galloway Intervals</span>' +
        '</button>' +
        '<button class="mode-btn ' + (currentMode === 'treadmill' ? 'mode-active treadmill-active' : '') + '" data-mode="treadmill">' +
          '<span class="mode-emoji">\uD83C\uDFBD</span>' +
          '<span class="mode-text">TREADMILL</span>' +
          '<span class="mode-sub">iFit Guided Run</span>' +
        '</button>' +
      '</div>' +
    '</div>';
  }

  // INTERVAL VISUAL (only for outdoor mode)
  var intervalHTML = '';
  if ((day.type === 'run' || day.type === 'longrun') && currentMode === 'outdoor') {
    var reps = day.type === 'longrun' ? 8 : 5;
    var blocks = '';
    for (var i = 0; i < reps; i++) {
      blocks += '<div class="iblock run"></div><div class="iblock walk"></div>';
    }
    blocks += '<span style="font-family:Bangers,cursive;font-size:18px;color:var(--ink);align-self:center;margin-left:4px">\u00B7\u00B7\u00B7</span>';
    intervalHTML = '<div class="interval-visual">' +
      '<div class="interval-label">\u26A1 INTERVAL PATTERN:</div>' +
      '<div class="interval-blocks">' + blocks + '</div>' +
      '<div class="interval-legend">' +
        '<span><span class="ileg-dot" style="background:var(--red)"></span>60s RUN</span>' +
        '<span><span class="ileg-dot" style="background:var(--blue);opacity:0.7"></span>30s WALK</span>' +
      '</div>' +
    '</div>';
  }

  // iFit BADGE (treadmill mode)
  var ifitBadgeHTML = '';
  if (hasIfitOption && currentMode === 'treadmill') {
    ifitBadgeHTML = '<div class="ifit-badge">\uD83C\uDFBD iFIT GUIDED RUN \u2014 Choose Your Own Adventure!</div>';
  }

  // SELECT STEPS based on mode
  var activeSteps = (currentMode === 'treadmill' && day.ifitSteps) ? day.ifitSteps : day.steps;
  var subtitleText = day.duration + ' \u00B7 ' + (hasIfitOption && currentMode === 'treadmill' ? 'iFIT GUIDED' : day.intervals);

  var stepsHTML = activeSteps.map(function(step, i) {
    var isChecked = checkedSteps[i];
    return '<div class="step ' + (isChecked ? 'checked' : '') + '" data-step="' + i + '">' +
      '<div class="step-num">' + (isChecked ? '' : (i+1)) + '</div>' +
      '<div class="step-body">' +
        '<div class="step-text">' + step.text + '</div>' +
        '<div class="step-time">' + step.time + '</div>' +
      '</div>' +
    '</div>';
  }).join('');

  var xpBadge = '<div style="text-align:center;padding:8px 14px 4px;font-family:Bangers,cursive;font-size:12px;letter-spacing:2px;color:' + (isDone ? 'var(--green)' : isSkipped ? 'var(--orange)' : 'rgba(0,0,0,0.3)') + ';">' +
    (isDone ? '\u2705 +' + (day.xp || 30) + ' XP EARNED!' : isSkipped ? '\u23ED SKIPPED \u2014 0 XP' : '\u26A1 COMPLETE FOR +' + (day.xp || 30) + ' XP') +
  '</div>';

  var btnHTML = '';
  if (isSkipped) {
    btnHTML = '<div class="complete-wrap"><button class="complete-btn skipped-btn" id="completeBtn">' +
      '\u23ED\uFE0F MISSION SKIPPED' +
    '</button></div>' +
    '<div class="skip-wrap"><button class="skip-btn" id="unskipBtn">\u21A9 UNDO SKIP \u2014 I changed my mind!</button></div>';
  } else if (day.type !== 'rest') {
    btnHTML = '<div class="complete-wrap"><button class="complete-btn ' + (isDone ? 'done-btn' : day.btnClass) + '" id="completeBtn">' +
      (isDone ? '\u2705 MISSION COMPLETE!' : '\u26A1 MISSION ACCOMPLISHED!') +
    '</button></div>' +
    (isDone ? '' : '<div class="skip-wrap"><button class="skip-btn" id="skipBtn">\u23ED Skip this mission \u2014 life happens!</button></div>');
  } else {
    btnHTML = '<div class="complete-wrap"><button class="complete-btn ' + (isDone ? 'done-btn' : '') + '" id="completeBtn" style="' + (isDone ? '' : 'background:#bbb;color:var(--ink);') + '">' +
      (isDone ? '\u2705 REST LOGGED!' : '\uD83D\uDE34 LOG REST DAY') +
    '</button></div>';
  }

  // SWAP DAY BUTTON
  var swapHTML = '';
  var swapped = isDateSwapped(activeDate);
  if (swapped) {
    var swaps = getSwaps();
    var partnerDate = swaps[activeDate];
    var partnerDateObj = new Date(partnerDate + 'T12:00:00');
    var originalDay = getOriginalDayForDate(activeDate);
    swapHTML = '<div class="swap-wrap">' +
      '<div class="swap-indicator">\uD83D\uDD00 SWAPPED FROM ' + WEEK_DAYS[partnerDateObj.getDay()] + ' ' + partnerDateObj.getDate() +
        ' <span style="color:rgba(0,0,0,0.35);">(was ' + (originalDay ? originalDay.title : '—') + ')</span>' +
      '</div>' +
      '<button class="swap-undo" id="swapUndoBtn">\u21A9 UNDO</button>' +
    '</div>';
  } else {
    swapHTML = '<div class="swap-wrap">' +
      '<div class="swap-label">\uD83D\uDCC5 BUSY DAY?</div>' +
      '<button class="swap-btn" id="swapDayBtn"><span class="swap-icon">\uD83D\uDD00</span> SWAP DAY</button>' +
    '</div>';
  }

  content.innerHTML = '<div class="workout-panel">' +
    '<div class="panel-header ' + day.headerClass + '">' +
      '<div class="pow-badge">' + day.pow + '</div>' +
      '<div class="header-top-row">' +
        '<div class="panel-icon">' + day.icon + '</div>' +
        '<div class="panel-titles">' +
          '<div class="panel-title">' + day.title + '</div>' +
          '<div class="panel-subtitle">' + subtitleText + '</div>' +
        '</div>' +
      '</div>' +
    '</div>' +
    swapHTML +
    toggleHTML +
    ifitBadgeHTML +
    intervalHTML +
    '<div class="steps-section">' +
      '<div class="steps-title">\uD83D\uDCCB MISSION BRIEFING</div>' +
      stepsHTML +
    '</div>' +
    xpBadge +
    btnHTML +
  '</div>';

  // MODE TOGGLE LISTENERS
  content.querySelectorAll('.mode-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var newMode = btn.dataset.mode;
      if (!state[activeDate]) state[activeDate] = {};
      // Reset step checks when switching modes
      if (state[activeDate].mode !== newMode) {
        state[activeDate].steps = {};
      }
      state[activeDate].mode = newMode;
      saveState(state);
      renderMoto();
      renderWorkout();
    });
  });

  // SWAP DAY LISTENERS
  var swapBtn = document.getElementById('swapDayBtn');
  if (swapBtn) {
    swapBtn.addEventListener('click', function() {
      showSwapModal(activeDate);
    });
  }
  var undoBtn = document.getElementById('swapUndoBtn');
  if (undoBtn) {
    undoBtn.addEventListener('click', function() {
      undoSwap(activeDate);
      renderAll();
    });
  }

  content.querySelectorAll('.step').forEach(function(el) {
    el.addEventListener('click', function() {
      var i = parseInt(el.dataset.step);
      if (!state[activeDate]) state[activeDate] = {};
      if (!state[activeDate].steps) state[activeDate].steps = {};
      state[activeDate].steps[i] = !state[activeDate].steps[i];
      saveState(state);
      if (state[activeDate].steps[i]) spawnMiniSfx(el);
      renderWorkout();
    });
  });

  var btn = document.getElementById('completeBtn');
  if (btn && !isSkipped) {
    btn.addEventListener('click', function() {
      if (!state[activeDate]) state[activeDate] = {};
      var wasNotDone = !state[activeDate].done;
      state[activeDate].done = !state[activeDate].done;
      saveState(state);
      if (state[activeDate].done && wasNotDone) {
        fireActionWord();
        fireConfetti();
        shakeScreen();
        checkAchievements();
      }
      renderAll();
    });
  }

  // SKIP / UNSKIP LISTENERS
  var skipBtn = document.getElementById('skipBtn');
  if (skipBtn) {
    skipBtn.addEventListener('click', function() {
      if (!state[activeDate]) state[activeDate] = {};
      state[activeDate].skipped = true;
      state[activeDate].done = false;
      state[activeDate].steps = {};
      saveState(state);
      renderAll();
    });
  }
  var unskipBtn = document.getElementById('unskipBtn');
  if (unskipBtn) {
    unskipBtn.addEventListener('click', function() {
      if (!state[activeDate]) state[activeDate] = {};
      state[activeDate].skipped = false;
      saveState(state);
      renderAll();
    });
  }
}

// RENDER STORY RECAP
function renderStoryRecap() {
  var completed = getCompletedCount();
  var beat = STORY_BEATS[0];
  for (var i = 0; i < STORY_BEATS.length; i++) {
    if (completed >= STORY_BEATS[i].min) beat = STORY_BEATS[i];
  }
  document.getElementById('recapText').innerHTML = beat.text;
  document.getElementById('recapNext').textContent = beat.next;
}

// RENDER ALL
function renderAll() {
  renderProgress();
  renderHeroStrip();
  renderWeekGrid();
  renderMoto();
  renderTabs();
  renderWorkout();
  renderStoryRecap();
}

// EFFECTS
function fireActionWord() {
  var word = ACTION_WORDS[Math.floor(Math.random() * ACTION_WORDS.length)];
  var colors = ['var(--yellow)','var(--red)','var(--cyan)'];
  
  var burst = document.createElement('div');
  burst.className = 'action-burst';
  burst.innerHTML = '<svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg"><polygon points="100,10 120,75 190,75 130,115 150,180 100,140 50,180 70,115 10,75 80,75" fill="' + colors[Math.floor(Math.random()*colors.length)] + '" stroke="var(--ink)" stroke-width="3"/></svg>';
  document.body.appendChild(burst);
  setTimeout(function(){ burst.remove(); }, 1100);

  var el = document.createElement('div');
  el.className = 'action-word';
  el.textContent = word;
  document.body.appendChild(el);
  setTimeout(function(){ el.remove(); }, 1100);
}

function fireConfetti() {
  var container = document.getElementById('confetti');
  container.innerHTML = '';
  var colors = ['#FFE338','#E8142A','#1A47B8','#00D166','#00CFFF','#8B5CF6','#FF6B2B','#fff'];
  var shapes = ['\u25A0','\u25CF','\u25B2','\u2605','\u25C6','\u26A1','\uD83D\uDCA5'];
  for (var i = 0; i < 60; i++) {
    var piece = document.createElement('div');
    var x = Math.random() * 100;
    var size = 10 + Math.random() * 16;
    var duration = 1 + Math.random() * 2;
    var delay = Math.random() * 0.5;
    var spin = Math.random() * 720;
    piece.style.cssText = 'position:absolute;left:' + x + '%;top:-20px;color:' + colors[Math.floor(Math.random()*colors.length)] + ';font-size:' + size + 'px;font-family:Bangers,cursive;opacity:0;animation:confettiFall ' + duration + 's ' + delay + 's ease-in forwards;transform:rotate(' + spin + 'deg);text-shadow:1px 1px 0 rgba(0,0,0,0.3);';
    piece.textContent = shapes[Math.floor(Math.random()*shapes.length)];
    container.appendChild(piece);
  }
  setTimeout(function(){ container.innerHTML = ''; }, 4000);
}

function shakeScreen() {
  document.body.classList.add('shake');
  setTimeout(function(){ document.body.classList.remove('shake'); }, 400);
}

function spawnMiniSfx(el) {
  var sfx = document.createElement('div');
  var words = ['\u2713','\u2714','\uD83D\uDCA5','\u26A1','\u2728'];
  sfx.style.cssText = 'position:absolute;right:-5px;top:-10px;font-size:16px;font-family:Bangers,cursive;pointer-events:none;z-index:10;animation:miniPop 0.5s ease-out forwards;';
  sfx.textContent = words[Math.floor(Math.random()*words.length)];
  el.style.position = 'relative';
  el.appendChild(sfx);
  setTimeout(function(){ sfx.remove(); }, 600);
}

function spawnAmbientSfx() {
  var container = document.getElementById('floatingSfx');
  setInterval(function() {
    if (Math.random() > 0.3) return;
    var word = SFX_WORDS[Math.floor(Math.random() * SFX_WORDS.length)];
    var el = document.createElement('div');
    el.className = 'sfx-word';
    el.textContent = word;
    var sfxColors = ['var(--red)','var(--blue)','var(--purple)','var(--ink)'];
    el.style.cssText = 'left:' + (10 + Math.random() * 80) + '%;top:' + (20 + Math.random() * 60) + '%;font-size:' + (14 + Math.random() * 12) + 'px;color:' + sfxColors[Math.floor(Math.random()*sfxColors.length)] + ';letter-spacing:2px;';
    container.appendChild(el);
    setTimeout(function(){ el.remove(); }, 4500);
  }, 5000);
}

// ACHIEVEMENTS
function checkAchievements() {
  var stats = {
    completedCount: getCompletedCount(),
    streak: getStreak(),
    totalDays: planDays.length,
    longRunsDone: planDays.filter(function(d){ var sd = getDayForDate(d.date); return sd && sd.type === 'longrun' && state[d.date] && state[d.date].done; }).length,
  };

  if (!state._achievements) state._achievements = {};

  for (var i = 0; i < ACHIEVEMENTS.length; i++) {
    var ach = ACHIEVEMENTS[i];
    if (!state._achievements[ach.id] && ach.check(stats)) {
      state._achievements[ach.id] = true;
      saveState(state);
      showAchievement(ach.text);
      return;
    }
  }
}

function showAchievement(text) {
  var toast = document.getElementById('achievementToast');
  toast.textContent = text;
  toast.classList.add('show');
  setTimeout(function(){ toast.classList.remove('show'); }, 3500);
}

// DYNAMIC CSS
var dynamicStyles = document.createElement('style');
dynamicStyles.textContent = '@keyframes confettiFall{0%{opacity:1;transform:translateY(0) rotate(0deg);}100%{opacity:0;transform:translateY(100vh) rotate(720deg);}}@keyframes miniPop{0%{opacity:1;transform:scale(0.5) translateY(0);}100%{opacity:0;transform:scale(1.5) translateY(-20px);}}';
document.head.appendChild(dynamicStyles);

// INIT
renderAll();
if (state._splashSeen) {
  setTimeout(spawnAmbientSfx, 2000);
}
</script>
</body>
</html>
